# =============================================================================
# Aureon-LLM — Railway Variables
# =============================================================================
# Copy this entire file into Railway → your web service → Variables → Raw Editor
#
# Secrets: after first deploy, open Railway deploy logs or run:
#   cat data/railway-secrets.json
# Paste AUREON_API_KEY and AUREON_AUDIT_CHAIN_KEY below so they survive redeploys.
#
# Postgres: add the Railway Postgres plugin, then keep DATABASE_URL as shown.
# Volume: add a volume mounted at /data so SQLite + secrets persist without Postgres.
# =============================================================================

# --- Secrets (paste from data/railway-secrets.json after first boot) ---
AUREON_API_KEY=
AUREON_AUDIT_CHAIN_KEY=

# --- Database (use Railway Postgres reference when plugin is attached) ---
DATABASE_URL=${{Postgres.DATABASE_URL}}

# --- Persistent data (mount a Railway volume at /data) ---
AUREON_DATA_DIR=/data
AUREON_AUDIT_LOG_DIR=/data/audit

# --- Auto-learn (defaults: ON on Railway) ---
AUREON_AUTO_LEARN=1
AUREON_AUTO_LEARN_ON_STARTUP=1
AUREON_AUTO_LEARN_INTERVAL_SEC=3600
AUREON_AUTO_LEARN_EPOCHS=150
AUREON_AUTO_LEARN_MAX_GRADES=1
AUREON_AUTO_LEARN_DOMAIN_LIMIT=2
AUREON_AUTO_LEARN_SUBDOMAIN_LIMIT=1
AUREON_AUTO_LEARN_MICRO_LIMIT=1

# --- Activity logging (JSON lines in Railway logs — filter: aureon.ai) ---
AUREON_ACTIVITY_LOG=1
AUREON_LOG_JSON=1
AUREON_LOG_LEVEL=INFO

# --- Security / nomad organism ---
AUREON_REPLAY_GUARD=1
AUREON_RATE_LIMIT_PER_MINUTE=30
AUREON_CHAOS_VEIL=1
AUREON_CHAOS_JITTER_MS=40
AUREON_ORGANISM_PULSE_MS=30000
AUREON_VAULT_BIND_FINGERPRINT=1

# --- Optional security hardening (uncomment to enable) ---
# AUREON_CLIENT_ALLOWLIST=
# AUREON_REQUIREMENTS_SHA256=

# --- Optional toggles ---
AUREON_PRELOAD_OLIVETTI=0

# --- Railway sets PORT automatically — do not override unless needed ---
# PORT=8080
