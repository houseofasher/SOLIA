"""Railway deployment env checklist — optional when auto-bootstrap is enabled."""

# Auto-provisioned on Railway if unset (persisted under data/railway-secrets.json):
# AUREON_API_KEY
# AUREON_AUDIT_CHAIN_KEY
# DATABASE_URL (SQLite fallback if Postgres not linked)

# Recommended — attach Railway Postgres plugin, then set:
DATABASE_URL=${{Postgres.DATABASE_URL}}

# Or copy generated secrets from data/railway-secrets.json into Railway variables:
# AUREON_API_KEY=
# AUREON_AUDIT_CHAIN_KEY=

# Persistent data directory (mount a Railway volume at /data for best results)
AUREON_DATA_DIR=/data

# Automated learning (defaults ON when Railway + Postgres detected)
AUREON_AUTO_LEARN=1
AUREON_AUTO_LEARN_ON_STARTUP=1
AUREON_AUTO_LEARN_INTERVAL_SEC=3600
AUREON_AUTO_LEARN_MAX_GRADES=1
AUREON_AUTO_LEARN_EPOCHS=150

# Activity logging — every AI action as JSON lines in Railway logs (default ON on Railway)
AUREON_ACTIVITY_LOG=1
AUREON_LOG_JSON=1
AUREON_LOG_LEVEL=INFO

# Optional — nomad chaos timing veil on mutating routes (default ON)
AUREON_CHAOS_VEIL=1
AUREON_CHAOS_JITTER_MS=40

# Background organism pulse (nomad NOMAD_ORGANISM_PULSE_MS)
AUREON_ORGANISM_PULSE_MS=30000

# Client allowlist — comma-separated sha256(api_key) or raw keys (optional)
# AUREON_CLIENT_ALLOWLIST=

# Pin requirements.txt at deploy time (optional)
# AUREON_REQUIREMENTS_SHA256=

# Optional
AUREON_AUDIT_LOG_DIR=/tmp/aureon-audit
AUREON_PRELOAD_OLIVETTI=0
